# --- HTTP server ---
PORT=3000
# Built Angular SPA dir (served if present). Docker image places it here.
FRONTEND_DIR=frontend/dist/frontend/browser

# --- Device credential derivation ---
# 256-bit hex secret, generate once: openssl rand -hex 32
# Used to derive per-device topic_id / username / password from MAC.
DEVICE_SECRET=change_me_openssl_rand_hex_32

# --- MQTT (server's own identity, provisioned in dynsec) ---
MQTT_URL=mqtt://mosquitto:1883
MQTT_SERVER_USERNAME=server
MQTT_SERVER_PASSWORD=change_me
# ms to wait for a device config/ack before reporting the set as unconfirmed
ACK_TIMEOUT_MS=5000

# --- mosquitto_ctrl provisioning (dynamic security plugin admin) ---
# Runs `docker run --rm --network <NETWORK> eclipse-mosquitto:2 mosquitto_ctrl ...`
MOSQUITTO_ADMIN_USER=admin
MOSQUITTO_ADMIN_PASS=change_me
MOSQUITTO_BROKER_HOST=mosquitto
MOSQUITTO_BROKER_PORT=1883
MOSQUITTO_NETWORK=traefik_net
# set to "native" to call mosquitto_ctrl directly (needs mosquitto-clients on host)
# instead of wrapping it in `docker run` (default "docker")
MOSQUITTO_CTRL_MODE=docker

# --- NeDB datastore files ---
DB_DEVICES_PATH=data/devices.db
DB_ARTICLES_PATH=data/articles.db
DB_ADMINS_PATH=data/admins.db

# --- Admin bootstrap (seeds an admin on first start if the store is empty) ---
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASS=change_me
