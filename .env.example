# --- HTTP server ---
PORT=3000
# Built Angular SPA dir (served if present). Docker image places it here.
FRONTEND_DIR=frontend/dist/frontend/browser

# --- Device credential derivation ---
# 256-bit hex secret, generate once: openssl rand -hex 32
# Used to derive per-device topic_id / username / password from MAC.
DEVICE_SECRET=change_me_openssl_rand_hex_32

# --- MQTT server identity (backend's own least-priv client) ---
# Auto-created/updated in dynsec on startup via the admin connection below.
MQTT_URL=mqtt://mosquitto:1883
MQTT_SERVER_USERNAME=server
MQTT_SERVER_PASSWORD=change_me
# ms to wait for a device config/ack before reporting the set as unconfirmed
ACK_TIMEOUT_MS=5000

# --- dynsec admin (provisioning connection) ---
# Existing dynamic-security admin. Used only to publish dynsec control commands
# over MQTT (device provisioning + self-provisioning the server client above).
MOSQUITTO_ADMIN_USER=admin
MOSQUITTO_ADMIN_PASS=change_me
# ms to wait for a dynsec control response
DYNSEC_CONTROL_TIMEOUT_MS=5000

# --- NeDB datastore files ---
DB_DEVICES_PATH=data/devices.db
DB_PRESETS_PATH=data/presets.db

# --- External authentication (alleskasse) ---
# Login proxies here; the returned apiKey IS the accountId. checkLogin verifies
# a token (HTTP 200 + customerFound=true) and returns the account name.
# No local user/account management exists — accounts live in the external API.
AUTH_LOGIN_URL=https://api.alleskasse.de/auth/login
AUTH_CHECK_URL=https://api.alleskasse.de/checkLogin/
AUTH_CACHE_TTL_MS=60000
AUTH_TIMEOUT_MS=8000

# --- Catalog source (articles/categories for building presets) ---
# "cloud" fetches from the degaso cloud with the account's apiKey; "mock" for dev.
CATALOG_SOURCE=cloud
CLOUD_API_URL=https://api.alleskasse.de
CLOUD_TIMEOUT_MS=10000
